# lla.ma base — connection config. Copy to .env (gitignored) and fill in.
# Point it at any PostgreSQL: local, RDS, Neon, a VPS, anything.

PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=

# Database used for server-level ops (list/create databases). CREATE DATABASE
# can't run inside another database's transaction, so it runs against this one.
# `postgres` is the conventional admin database.
PG_ADMIN_DB=postgres

# TLS: "off" for localhost / an SSH tunnel. Use "require" (skip cert check) or
# "verify" (enforce cert) when connecting directly over TLS (e.g. RDS/Neon).
PG_SSL=off

# Database engine. Postgres today; MySQL and Mongo planned.
LLAMA_DB_ENGINE=postgres

# --- SSH tunnel (optional) ---------------------------------------------------
# If your Postgres is only reachable over SSH (not exposed publicly — the safe
# setup), turn this on and `npm run dev` will open the tunnel for you. No second
# terminal, no manual ssh command. Leave SSH_TUNNEL unset for a direct/local DB.
#
# The tunnel's LOCAL end is PG_HOST:PG_PORT above — so set PG_HOST=127.0.0.1 and
# PG_PORT to a free local port (5433 is a good default if 5432 is taken locally).
#
# SSH_TUNNEL=on
# SSH_HOST=your-box.example.com   # the SSH server (often the DB box itself)
# SSH_USER=ubuntu
# SSH_KEY=~/.ssh/id_rsa           # private key; omit to use your ssh-agent
# SSH_PORT=22
# SSH_REMOTE_HOST=localhost       # the DB host as seen FROM the SSH box
# SSH_REMOTE_PORT=5432            # the DB port on that box
